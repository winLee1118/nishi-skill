NIHAIXIA_DB=data/nihaixia.sqlite
NIHAIXIA_VAULT=knowledge/vault
NIHAIXIA_GRAPH=knowledge/graph

# Optional: used later by answer generation adapters.
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

RAG_MODE=fts

# Optional hybrid vector search. Keep real keys only in local .env or system env.
EMBEDDING_PROVIDER=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIM=
VECTOR_STORE=sqlite
VECTOR_CACHE_DB=data/nihaixia.sqlite

# Doubao / Volcano Ark example, leave API key empty in committed files.
# Vision embedding models use /embeddings/multimodal automatically.
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# EMBEDDING_MODEL=doubao-embedding-vision-251215
# EMBEDDING_DIM=1024
